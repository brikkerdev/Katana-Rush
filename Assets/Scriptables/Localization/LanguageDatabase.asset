    - languageCode: ru
      text: "\u0421\u043E\u0431\u0435\u0440\u0438\u0442\u0435 50000 \u043C\u043E\u043D\u0435\u0442"
  - key: katana_name_windwalker
    translations:
    - languageCode: en
      text: Windwalker
    - languageCode: ru
      text: "\u0421\u0442\u0440\u0430\u043D\u043D\u0438\u043A \u0432\u0435\u0442\u0440\u0430"
  - key: katana_description_windwalker
    translations:
    - languageCode: en
      text: Double jump, slow fall, extreme mobility
    - languageCode: ru
      text: "\u0414\u0432\u043E\u0439\u043D\u043E\u0439 \u043F\u0440\u044B\u0436\u043E\u043A,
        \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u0435"
  - key: challenge_50k_jumps
    translations:
    - languageCode: en
      text: Perform 50000 jumps in total
