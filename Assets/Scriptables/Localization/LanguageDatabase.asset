        \u0443\u0440\u043E\u043D \u0440\u044B\u0432\u043A\u0430"
  - key: katana_name_aurora
    translations:
    - languageCode: en
      text: Aurora
    - languageCode: ru
      text: "\u0410\u0432\u0440\u043E\u0440\u0430"
  - key: katana_description_aurora
    translations:
    - languageCode: en
