        \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C"
  - key: challenge_10k_highscore
    translations:
    - languageCode: en
      text: Achieve a highscore of 10000
    - languageCode: ru
      text: "\u0414\u043E\u0441\u0442\u0438\u0433\u043D\u0438\u0442\u0435 \u0440\u0435\u043A\u043E\u0440\u0434\u0430
        \u0432 10000 \u043E\u0447\u043A\u043E\u0432"
  - key: katana_name_midas
    translations:
    - languageCode: en
      text: Midas Touch
    - languageCode: ru
      text: "\u041F\u0440\u0438\u043A\u043E\u0441\u043D\u043E\u0432\u0435\u043D\u0438\u0435
