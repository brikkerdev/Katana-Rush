    - languageCode: ru
      text: "\u041F\u043E\u0431\u0435\u0434\u0438\u0442\u0435 5000 \u0432\u0440\u0430\u0433\u043E\u0432"
  - key: katana_name_berserker
    translations:
    - languageCode: en
      text: Berserker
    - languageCode: ru
      text: "\u0411\u0435\u0440\u0441\u0435\u0440\u043A"
  - key: katana_description_berserker
    translations:
