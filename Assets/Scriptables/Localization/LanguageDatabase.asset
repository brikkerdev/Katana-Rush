  - key: tip_1
    translations:
    - languageCode: en
      text: Dash through enemies to defeat them!
    - languageCode: ru
      text: "\u0414\u0435\u043B\u0430\u0439\u0442\u0435 \u0440\u044B\u0432\u043E\u043A
