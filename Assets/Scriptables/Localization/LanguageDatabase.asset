    - languageCode: ru
      text: "\u041F\u043E\u0433\u043B\u043E\u0449\u0430\u0435\u0442 \u043E\u0434\u0438\u043D
        \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0443\u0434\u0430\u0440"
  - key: katana_name_eclipse
