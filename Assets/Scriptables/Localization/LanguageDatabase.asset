    - languageCode: ru
      text: "\u0422\u0440\u043E\u0439\u043D\u044B\u0435 \u043C\u043E\u043D\u0435\u0442\u044B,
        \u0441\u0435\u0440\u0438\u044F \u043C\u043E\u043D\u0435\u0442, \u043C\u0430\u0433\u043D\u0438\u0442"
  - key: challenge_50k_coins_collected
    translations:
    - languageCode: en
