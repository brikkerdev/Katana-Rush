    translations:
    - languageCode: en
      text: Venom Fang
    - languageCode: ru
      text: "\u042F\u0434\u043E\u0432\u0438\u0442\u044B\u0439 \u043A\u043B\u044B\u043A"
  - key: katana_description_venom
    translations:
    - languageCode: en
      text: Increased dash damage
    - languageCode: ru
      text: "\u0423\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u043D\u044B\u0439 \u0443\u0440\u043E\u043D
        \u0440\u044B\u0432\u043A\u0430"
  - key: katana_name_crimson
    translations:
    - languageCode: en
      text: Crimson Tide
    - languageCode: ru
      text: "\u0411\u0430\u0433\u0440\u043E\u0432\u044B\u0439 \u043F\u0440\u0438\u043B\u0438\u0432"
  - key: katana_description_crimson
    translations:
    - languageCode: en
      text: Extended dash invincibility
    - languageCode: ru
      text: "\u041F\u0440\u043E\u0434\u043B\u0451\u043D\u043D\u0430\u044F \u043D\u0435\u0443\u044F\u0437\u0432\u0438\u043C\u043E\u0441\u0442\u044C
        \u0440\u044B\u0432\u043A\u0430"
  - key: katana_name_sakura
    translations:
    - languageCode: en
      text: Sakura
    - languageCode: ru
      text: "\u0421\u0430\u043A\u0443\u0440\u0430"
  - key: katana_description_sakura
    translations:
    - languageCode: en
      text: Coin magnet aura
    - languageCode: ru
      text: "\u041C\u0430\u0433\u043D\u0438\u0442 \u0434\u043B\u044F \u043C\u043E\u043D\u0435\u0442"
  - key: katana_name_titanium
    translations:
    - languageCode: en
      text: Titanium Edge
    - languageCode: ru
      text: "\u0422\u0438\u0442\u0430\u043D\u043E\u0432\u044B\u0439 \u043A\u043B\u0438\u043D\u043E\u043A"
  - key: katana_description_titanium
    translations:
    - languageCode: en
      text: Score multiplier 1.25x
    - languageCode: ru
      text: "\u041C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u044C \u043E\u0447\u043A\u043E\u0432
        1.25x"
  - key: katana_name_phantom
    translations:
    - languageCode: en
      text: Phantom Blade
    - languageCode: ru
      text: "\u041F\u0440\u0438\u0437\u0440\u0430\u0447\u043D\u044B\u0439 \u043A\u043B\u0438\u043D\u043E\u043A"
  - key: katana_description_phantom
    translations:
    - languageCode: en
      text: Invincibility after landing
    - languageCode: ru
      text: "\u041D\u0435\u0443\u044F\u0437\u0432\u0438\u043C\u043E\u0441\u0442\u044C
