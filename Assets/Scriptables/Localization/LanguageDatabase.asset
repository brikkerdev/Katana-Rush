    translations:
    - languageCode: en
      text: Speed surge after killing enemies
    - languageCode: ru
      text: "\u0423\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435 \u043F\u043E\u0441\u043B\u0435
