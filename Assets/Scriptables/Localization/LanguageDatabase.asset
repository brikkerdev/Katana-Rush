      text: "\u0420\u044B\u0432\u043E\u043A \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
        \u043F\u0440\u0438 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0435"
  - key: challenge_50_kill_streak
    translations:
    - languageCode: en
      text: Achieve a 50 kill streak
    - languageCode: ru
      text: "\u0414\u043E\u0441\u0442\u0438\u0433\u043D\u0438\u0442\u0435 \u0441\u0435\u0440\u0438\u0438
        \u0438\u0437 50 \u0443\u0431\u0438\u0439\u0441\u0442\u0432"
  - key: katana_name_marathon
    translations:
    - languageCode: en
      text: Marathon
    - languageCode: ru
      text: "\u041C\u0430\u0440\u0430\u0444\u043E\u043D"
  - key: katana_description_marathon
    translations:
